@using FWO.Api.Client.Queries
@using FWO.Config.Api.Data
@using FWO.Data.Modelling
@using FWO.Data.Workflow
@using FWO.Services
@using FWO.Ui.Services

@inject ApiConnection apiConnection
@inject UserConfig userConfig

<div class="mt-2">
    <div class="d-flex align-items-center gap-2 mb-2">
        <h5 class="mb-0">@(userConfig.GetText("using_states"))</h5>
        <button type="button" class="btn btn-sm btn-success" @onclick="SelectStateLink">
            @(DisplayService.DisplayButton(userConfig, "add_state", Icons.Add))
        </button>
    </div>
    @if (ActAction.StateActions.Count > 0)
    {
        <Table class="table table-bordered table-sm th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="WfStateActionStateHelper" Items="ActAction.StateActions" PageSize="0" ColumnReorder="false">
            <Column TableItem="WfStateActionStateHelper" Title="@(userConfig.GetText("actions"))" Field="(x => x.State.Id)" Sortable="false" Filterable="false">
                <Template>
                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveStateLink(context)">
                        @(DisplayService.DisplayButton(userConfig, "remove", Icons.Delete))
                    </button>
                </Template>
            </Column>
            <Column TableItem="WfStateActionStateHelper" Title="@(userConfig.GetText("name"))" Field="@(x => x.State.Name)" Sortable="true" Filterable="true">
                <Template>
                    @(DisplayService.DisplayStateWithId(userConfig, context.State))
                </Template>
            </Column>
        </Table>
    }
    else
    {
        <span>-</span>
    }
</div>

<SelectStatePopup @bind-Display="selectStateMode"
                  Title="@(userConfig.GetText("select_state"))"
                  States="AvailableStateLinks"
                  @bind-SelectedState="selectedStateLink"
                  StateToString="@(s => DisplayService.DisplayStateWithId(userConfig, s))"
                  NoneSelectedText="@(userConfig.GetText("select_state"))"
                  OnConfirm="AddStateLink"
                  OnCancel="CancelSelectStateLink" />

@code {
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public WfStateAction ActAction { get; set; } = new();

    [Parameter]
    public List<WfState> States { get; set; } = [];

    [Parameter]
    public bool AddActionMode { get; set; }

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private bool selectStateMode;
    private WfState? selectedStateLink;

    protected override void OnParametersSet()
    {
        if (selectedStateLink == null)
        {
            selectedStateLink = AvailableStateLinks.FirstOrDefault();
        }
    }

    public async Task PersistPendingStateLinksAsync()
    {
        foreach (WfStateActionStateHelper stateAction in ActAction.StateActions)
        {
            WfState? state = States.FirstOrDefault(candidate => candidate.Id == stateAction.State.Id);
            if (state == null)
            {
                continue;
            }

            int sortOrder = NextActionSortOrder(state);
            stateAction.SortOrder = sortOrder;
            state.Actions.Add(new WfStateActionDataHelper
            {
                Action = ActAction,
                SortOrder = sortOrder
            });
            NormalizeActionSortOrder(state);
            await apiConnection.SendQueryAsync<object>(RequestQueries.addStateAction, new { stateId = state.Id, actionId = ActAction.Id, sortOrder });
            await SaveActionSortOrder(state);
        }
    }

    private void SelectStateLink()
    {
        selectedStateLink = AvailableStateLinks.FirstOrDefault();
        selectStateMode = true;
    }

    private void CancelSelectStateLink()
    {
        selectStateMode = false;
        selectedStateLink = null;
    }

    private List<WfState> AvailableStateLinks => States
        .Where(state => state.Id > 0 && ActAction.StateActions.All(link => link.State.Id != state.Id))
        .OrderBy(state => state.Id)
        .ToList();

    private async Task AddStateLink()
    {
        try
        {
            if (selectedStateLink == null)
            {
                return;
            }

            WfState state = States.FirstOrDefault(candidate => candidate.Id == selectedStateLink.Id) ?? throw new ArgumentException("no state selected");
            WfStateActionDataHelper newStateAction = new()
            {
                Action = ActAction,
                SortOrder = NextActionSortOrder(state)
            };

            if (!AddActionMode)
            {
                await apiConnection.SendQueryAsync<object>(RequestQueries.addStateAction, new { stateId = state.Id, actionId = ActAction.Id, sortOrder = newStateAction.SortOrder });
                state.Actions.Add(newStateAction);
                NormalizeActionSortOrder(state);
                await SaveActionSortOrder(state);
            }

            ActAction.StateActions.Add(new WfStateActionStateHelper
            {
                SortOrder = newStateAction.SortOrder,
                State = state
            });
            selectStateMode = false;
            selectedStateLink = null;
            if (!AddActionMode)
            {
                await OnChanged.InvokeAsync();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("edit_action"), "", true);
        }
    }

    private async Task RemoveStateLink(WfStateActionStateHelper stateAction)
    {
        try
        {
            WfState state = States.FirstOrDefault(candidate => candidate.Id == stateAction.State.Id) ?? throw new ArgumentException("no state selected");
            WfStateActionDataHelper? linkedAction = state.Actions.FirstOrDefault(action => action.Action.Id == ActAction.Id);
            if (linkedAction == null)
            {
                ActAction.StateActions.Remove(stateAction);
                return;
            }

            if (!AddActionMode)
            {
                await apiConnection.SendQueryAsync<object>(RequestQueries.removeStateAction, new { stateId = state.Id, actionId = ActAction.Id });
                state.Actions.Remove(linkedAction);
                NormalizeActionSortOrder(state);
                await SaveActionSortOrder(state);
            }

            ActAction.StateActions.Remove(stateAction);
            if (!AddActionMode)
            {
                await OnChanged.InvokeAsync();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("edit_action"), "", true);
        }
    }

    private static int NextActionSortOrder(WfState state)
    {
        return state.Actions.Count == 0 ? 1 : state.Actions.Max(action => action.SortOrder) + 1;
    }

    private static void NormalizeActionSortOrder(WfState state)
    {
        for (int index = 0; index < state.Actions.Count; ++index)
        {
            state.Actions[index].SortOrder = index + 1;
        }
    }

    private async Task SaveActionSortOrder(WfState state)
    {
        foreach (WfStateActionDataHelper stateAction in state.Actions)
        {
            await apiConnection.SendQueryAsync<object>(RequestQueries.updateStateActionSortOrder, new
            {
                stateId = state.Id,
                actionId = stateAction.Action.Id,
                sortOrder = stateAction.SortOrder
            });
        }
    }
}
