@page "/settings/flows/general"

@using FWO.Api.Client.Queries
@using FWO.Config.Api
@using FWO.Config.Api.Data
@using FWO.Data
@using FWO.Data.Flow
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = $"{Roles.Admin}")]

@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig

<div class="input-group">
    <h3>@(userConfig.GetText("flow_general_settings"))</h3>
    <HelpLink Page="settings/flows/general" />
</div>

<div class="mb-2">
    <label class="form-label form-label-sm mb-1">@(userConfig.GetText("flow_naming")):</label>
    <div>
        @if (namingManagementRanking.Count > 0)
        {
            <table class="table table-sm table-bordered th-bg-secondary mb-0 w-auto">
                <thead>
                    <tr>
                        <th class="text-nowrap">@(userConfig.GetText("sort_order"))</th>
                        <th>@(userConfig.GetText("management"))</th>
                        <th class="text-nowrap">@(userConfig.GetText("actions"))</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int index = 0; index < namingManagementRanking.Count; index++)
                    {
                        Management management = namingManagementRanking[index];
                        <tr @key="management.Id">
                            <td>@(index + 1)</td>
                            <td>@management.Name</td>
                            <td>
                                <div class="btn-group">
                                    <button type="button" class="btn btn-sm btn-secondary" disabled="@(index == 0)" @onclick:stopPropagation="true" @onclick="() => MoveNamingManagement(management, -1)" title="@(userConfig.GetText("move_up"))">
                                        <span class="@Icons.CollapseUp"></span>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-secondary" disabled="@(index == namingManagementRanking.Count - 1)" @onclick:stopPropagation="true" @onclick="() => MoveNamingManagement(management, 1)" title="@(userConfig.GetText("move_down"))">
                                        <span class="@Icons.CollapseDown"></span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-muted small">-</div>
        }
        <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
            <div class="btn-group">
                <button type="button" class="btn btn-sm btn-primary" disabled="@workInProgress" @onclick="SaveNamingSource">
                    @if (workInProgress)
                    {
                        <Loading CssClass="me-1" />
                    }
                    @(DisplayService.DisplayButton(userConfig, "save", Icons.Save))
                </button>
                <button type="button" class="btn btn-sm btn-warning" disabled="@workInProgress" @onclick="OpenRecalculateConfirm">@(DisplayService.DisplayButton(userConfig, "recalculate_flow_names", Icons.Refresh))</button>
            </div>
            <div class="text-muted small">
                @($"{userConfig.GetText("current")}: {SelectedNamingManagement?.Name ?? "-"}")
            </div>
        </div>
    </div>
</div>

<div class="mb-2">
    <label class="form-label form-label-sm mb-1">@(userConfig.GetText("reset_flow_db")):</label>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button type="button" class="btn btn-sm btn-danger" disabled="@workInProgress" @onclick="OpenResetFlowDbConfirm">
            @(DisplayService.DisplayButton(userConfig, "reset_flow_db", Icons.Refresh))
        </button>
        <div class="text-muted small">
            @(userConfig.GetText("reset_flow_db_hint"))
        </div>
    </div>
</div>

<Confirm @bind-Display="RecalculateConfirmMode" PerformAction="RecalculateFlowNames" Title="@(userConfig.GetText("recalculate_flow_names"))"
         Message="@(userConfig.GetText("recalculate_flow_names_confirm"))" />

<Confirm @bind-Display="ResetFlowDbConfirmMode" PerformAction="ResetFlowDb" Title="@(userConfig.GetText("reset_flow_db"))"
         Message="@(userConfig.GetText("reset_flow_db_confirm"))" />

<InProgress Display="workInProgress" />

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<FlowNwObject> flowNwObjects = [];
    private List<FlowNwGroup> flowNwGroups = [];
    private List<FlowSvcObject> flowSvcObjects = [];
    private List<FlowSvcGroup> flowSvcGroups = [];
    private List<FlowTimeObject> flowTimeObjects = [];
    private List<Management> selectableManagements = [];
    private List<Management> namingManagementRanking = [];
    private List<Management> namingNetworkObjectManagements = [];
    private List<Management> namingNetworkGroupManagements = [];
    private List<Management> namingServiceManagements = [];
    private List<Management> namingTimeManagements = [];
    private ConfigData? configData;
    private bool workInProgress = false;
    private bool RecalculateConfirmMode = false;
    private bool ResetFlowDbConfirmMode = false;

    private Management? SelectedNamingManagement => namingManagementRanking.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        try
        {
            workInProgress = true;
            StateHasChanged();

            if (!userConfig.CanUseAnyRole(Roles.Admin))
            {
                workInProgress = false;
                return;
            }

            configData = await globalConfig.GetEditableConfig();
            selectableManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowSelectableManagements);
            InitializeNamingManagementRanking();
            flowNwObjects = await apiConnection.SendQueryAsync<List<FlowNwObject>>(FlowQueries.getFlowNwObjectCatalog);
            flowNwGroups = await apiConnection.SendQueryAsync<List<FlowNwGroup>>(FlowQueries.getFlowAddressGroups) ?? [];
            flowSvcObjects = await apiConnection.SendQueryAsync<List<FlowSvcObject>>(FlowQueries.getFlowServiceObjects) ?? [];
            flowSvcGroups = await apiConnection.SendQueryAsync<List<FlowSvcGroup>>(FlowQueries.getFlowServiceGroups) ?? [];
            flowTimeObjects = await apiConnection.SendQueryAsync<List<FlowTimeObject>>(FlowQueries.getFlowTimeObjects) ?? [];
            await LoadNamingCandidateManagements();

            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("flow_general_settings"), "", true);
        }

        StateHasChanged();
    }

    private async Task SaveNamingSource()
    {
        try
        {
            if (configData == null)
            {
                return;
            }

            workInProgress = true;
            StateHasChanged();

            await SaveNamingManagementRankingAsync();
            List<int> preferredManagementRanking = GetNamingManagementRankingIds();
            await BackfillMissingNamesAsync(preferredManagementRanking);

            DisplayMessageInUi(null, userConfig.GetText("flow_naming"), userConfig.GetText("U5301"), false);
            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("flow_naming"), "", true);
        }

        StateHasChanged();
    }

    private async Task SaveNamingManagementRankingAsync()
    {
        if (configData == null)
        {
            return;
        }

        List<int> preferredManagementRanking = GetNamingManagementRankingIds();
        configData.FlowNamingSourceManagementRanking = FlowNamingHelper.SerializeManagementRanking(preferredManagementRanking);
        await globalConfig.WriteToDatabase(configData, apiConnection);
    }

    private void InitializeNamingManagementRanking()
    {
        if (configData == null)
        {
            namingManagementRanking = [.. selectableManagements];
            return;
        }

        List<int> preferredManagementRanking = FlowNamingHelper.ParseManagementRanking(configData.FlowNamingSourceManagementRanking);
        List<int> normalizedRanking = FlowNamingHelper.NormalizeManagementRanking(
            preferredManagementRanking,
            selectableManagements.Select(management => management.Id));

        Dictionary<int, Management> managementById = selectableManagements.ToDictionary(management => management.Id);
        namingManagementRanking = [.. normalizedRanking
            .Select(managementId => managementById.GetValueOrDefault(managementId))
            .Where(management => management != null)
            .Select(management => management!)];
    }

    private List<int> GetNamingManagementRankingIds()
    {
        return [.. namingManagementRanking.Select(management => management.Id)];
    }

    private void MoveNamingManagement(Management management, int offset)
    {
        int index = namingManagementRanking.FindIndex(item => item.Id == management.Id);
        int targetIndex = index + offset;
        if (index < 0 || targetIndex < 0 || targetIndex >= namingManagementRanking.Count)
        {
            return;
        }

        (namingManagementRanking[index], namingManagementRanking[targetIndex]) = (namingManagementRanking[targetIndex], namingManagementRanking[index]);
    }

    private void OpenRecalculateConfirm()
    {
        RecalculateConfirmMode = true;
    }

    private async Task RecalculateFlowNames()
    {
        try
        {
            if (configData == null)
            {
                return;
            }

            await SaveNamingManagementRankingAsync();
            RecalculateConfirmMode = false;
            workInProgress = true;
            StateHasChanged();

            List<int> preferredManagementRanking = FlowNamingHelper.ParseManagementRanking(configData.FlowNamingSourceManagementRanking);
            await RecalculateNamesAsync(preferredManagementRanking);

            workInProgress = false;
            await Refresh();
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("recalculate_flow_names"), "", true);
        }

        StateHasChanged();
    }

    private void OpenResetFlowDbConfirm()
    {
        ResetFlowDbConfirmMode = true;
    }

    private async Task ResetFlowDb()
    {
        try
        {
            ResetFlowDbConfirmMode = false;
            workInProgress = true;
            StateHasChanged();

            await apiConnection.SendQueryAsync<MutationResult>(FlowMutations.resetFlowDB);

            workInProgress = false;
            await Refresh();
            DisplayMessageInUi(null, userConfig.GetText("reset_flow_db"), userConfig.GetText("U5330"), false);
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("reset_flow_db"), "", true);
        }

        StateHasChanged();
    }

    private async Task LoadNamingCandidateManagements()
    {
        if (namingNetworkObjectManagements.Count > 0 ||
            namingNetworkGroupManagements.Count > 0 ||
            namingServiceManagements.Count > 0 ||
            namingTimeManagements.Count > 0)
        {
            return;
        }

        List<int> managementIds = [.. selectableManagements.Select(management => management.Id)];
        if (managementIds.Count == 0)
        {
            namingNetworkObjectManagements = [];
            namingNetworkGroupManagements = [];
            namingServiceManagements = [];
            namingTimeManagements = [];
            return;
        }

        namingNetworkObjectManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowCustomObjectNamingCandidates, new
        {
            management_id = managementIds
        }) ?? [];
        namingNetworkGroupManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowCustomObjectCandidates, new
        {
            management_id = managementIds
        }) ?? [];
        namingServiceManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowCustomServiceCandidates, new
        {
            management_id = managementIds
        }) ?? [];
        namingTimeManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowCustomTimeObjectCandidates, new
        {
            management_id = managementIds
        }) ?? [];
    }

    private void ReplaceFlowNwObjectInCatalog(FlowNwObject updatedObject)
    {
        int objectIndex = flowNwObjects.FindIndex(flowObject => flowObject.Id == updatedObject.Id);
        if (objectIndex >= 0)
        {
            flowNwObjects[objectIndex] = updatedObject;
        }
    }

    private void ReplaceFlowNwGroupInCatalog(FlowNwGroup updatedGroup)
    {
        int groupIndex = flowNwGroups.FindIndex(flowGroup => flowGroup.Id == updatedGroup.Id);
        if (groupIndex >= 0)
        {
            flowNwGroups[groupIndex] = updatedGroup;
        }
    }

    private void ReplaceFlowSvcObjectInCatalog(FlowSvcObject updatedObject)
    {
        int objectIndex = flowSvcObjects.FindIndex(flowObject => flowObject.Id == updatedObject.Id);
        if (objectIndex >= 0)
        {
            flowSvcObjects[objectIndex] = updatedObject;
        }
    }

    private void ReplaceFlowSvcGroupInCatalog(FlowSvcGroup updatedGroup)
    {
        int groupIndex = flowSvcGroups.FindIndex(flowGroup => flowGroup.Id == updatedGroup.Id);
        if (groupIndex >= 0)
        {
            flowSvcGroups[groupIndex] = updatedGroup;
        }
    }

    private void ReplaceFlowTimeObjectInCatalog(FlowTimeObject updatedObject)
    {
        int objectIndex = flowTimeObjects.FindIndex(flowObject => flowObject.Id == updatedObject.Id);
        if (objectIndex >= 0)
        {
            flowTimeObjects[objectIndex] = updatedObject;
        }
    }

    private async Task SendFlowBatchUpdateAsync(string mutation, List<object> updates, int expectedAffectedRows)
    {
        if (updates.Count == 0)
        {
            return;
        }

        List<MutationResult> result = await apiConnection.SendQueryAsync<List<MutationResult>>(mutation, new
        {
            updates
        }) ?? [];

        int affectedRows = result.Sum(item => item.AffectedRows);

        if (affectedRows != expectedAffectedRows)
        {
            throw new InvalidOperationException($"Expected {expectedAffectedRows} updated rows but got {affectedRows}.");
        }
    }

    /// <summary>
    /// Backfills missing names for all supported flow object types using the configured management ranking.
    /// </summary>
    private async Task BackfillMissingNamesAsync(IReadOnlyList<int> preferredManagementRanking)
    {
        List<FlowNwObject> updatedNwObjects = [];
        List<object> nwObjectUpdates = [];
        foreach (FlowNwObject nwObject in flowNwObjects
                     .Where(nwObject => string.IsNullOrWhiteSpace(nwObject.Name))
                     .ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveMissingNwObjectNameByRanking(nwObject, namingNetworkObjectManagements, preferredManagementRanking, "");
            if (string.IsNullOrWhiteSpace(resolvedName))
            {
                continue;
            }

            updatedNwObjects.Add(new FlowNwObject
            {
                Id = nwObject.Id,
                Name = resolvedName,
                IpStart = nwObject.IpStart,
                IpEnd = nwObject.IpEnd,
                Hash = nwObject.Hash,
                State = nwObject.State,
                RemovedDate = nwObject.RemovedDate,
                ShowInRequestModule = nwObject.ShowInRequestModule
            });
            nwObjectUpdates.Add(new
            {
                where = new { nwobj_id = new { _eq = nwObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = nwObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowNwObjects, nwObjectUpdates, updatedNwObjects.Count);
        foreach (FlowNwObject updatedObject in updatedNwObjects)
        {
            ReplaceFlowNwObjectInCatalog(updatedObject);
        }

        List<FlowNwGroup> updatedNwGroups = [];
        List<object> nwGroupUpdates = [];
        foreach (FlowNwGroup nwGroup in flowNwGroups
                     .Where(nwGroup => string.IsNullOrWhiteSpace(nwGroup.Name))
                     .ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveNwGroupNameByRanking(nwGroup, namingNetworkGroupManagements, preferredManagementRanking, "");
            if (string.IsNullOrWhiteSpace(resolvedName))
            {
                continue;
            }

            updatedNwGroups.Add(new FlowNwGroup
            {
                Id = nwGroup.Id,
                Name = resolvedName,
                Hash = nwGroup.Hash,
                State = nwGroup.State,
                RemovedDate = nwGroup.RemovedDate,
                ShowInRequestModule = nwGroup.ShowInRequestModule,
                NwGroupMembers = [.. nwGroup.NwGroupMembers]
            });
            nwGroupUpdates.Add(new
            {
                where = new { nwgrp_id = new { _eq = nwGroup.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = nwGroup.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowNwGroups, nwGroupUpdates, updatedNwGroups.Count);
        foreach (FlowNwGroup updatedGroup in updatedNwGroups)
        {
            ReplaceFlowNwGroupInCatalog(updatedGroup);
        }

        List<FlowSvcObject> updatedSvcObjects = [];
        List<object> svcObjectUpdates = [];
        foreach (FlowSvcObject svcObject in flowSvcObjects
                     .Where(svcObject => string.IsNullOrWhiteSpace(svcObject.Name))
                     .ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveMissingSvcObjectNameByRanking(svcObject, namingServiceManagements, preferredManagementRanking, "");
            if (string.IsNullOrWhiteSpace(resolvedName))
            {
                continue;
            }

            updatedSvcObjects.Add(new FlowSvcObject
            {
                Id = svcObject.Id,
                Name = resolvedName,
                PortStart = svcObject.PortStart,
                PortEnd = svcObject.PortEnd,
                ProtoId = svcObject.ProtoId,
                Hash = svcObject.Hash,
                State = svcObject.State,
                RemovedDate = svcObject.RemovedDate,
                ShowInRequestModule = svcObject.ShowInRequestModule
            });
            svcObjectUpdates.Add(new
            {
                where = new { svcobj_id = new { _eq = svcObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = svcObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowSvcObjects, svcObjectUpdates, updatedSvcObjects.Count);
        foreach (FlowSvcObject updatedObject in updatedSvcObjects)
        {
            ReplaceFlowSvcObjectInCatalog(updatedObject);
        }

        List<FlowSvcGroup> updatedSvcGroups = [];
        List<object> svcGroupUpdates = [];
        foreach (FlowSvcGroup svcGroup in flowSvcGroups
                     .Where(svcGroup => string.IsNullOrWhiteSpace(svcGroup.Name))
                     .ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveSvcGroupNameByRanking(svcGroup, namingServiceManagements, preferredManagementRanking, "");
            if (string.IsNullOrWhiteSpace(resolvedName))
            {
                continue;
            }

            updatedSvcGroups.Add(new FlowSvcGroup
            {
                Id = svcGroup.Id,
                Name = resolvedName,
                Hash = svcGroup.Hash,
                State = svcGroup.State,
                RemovedDate = svcGroup.RemovedDate,
                ShowInRequestModule = svcGroup.ShowInRequestModule,
                SvcGroupMembers = [.. svcGroup.SvcGroupMembers]
            });
            svcGroupUpdates.Add(new
            {
                where = new { svcgrp_id = new { _eq = svcGroup.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = svcGroup.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowSvcGroups, svcGroupUpdates, updatedSvcGroups.Count);
        foreach (FlowSvcGroup updatedGroup in updatedSvcGroups)
        {
            ReplaceFlowSvcGroupInCatalog(updatedGroup);
        }

        List<FlowTimeObject> updatedTimeObjects = [];
        List<object> timeObjectUpdates = [];
        foreach (FlowTimeObject timeObject in flowTimeObjects
                     .Where(timeObject => string.IsNullOrWhiteSpace(timeObject.Name))
                     .ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveMissingTimeObjectNameByRanking(timeObject, namingTimeManagements, preferredManagementRanking, "");
            if (string.IsNullOrWhiteSpace(resolvedName))
            {
                continue;
            }

            updatedTimeObjects.Add(new FlowTimeObject
            {
                Id = timeObject.Id,
                Name = resolvedName,
                StartTime = timeObject.StartTime,
                EndTime = timeObject.EndTime,
                Hash = timeObject.Hash,
                State = timeObject.State,
                RemovedDate = timeObject.RemovedDate,
                ShowInRequestModule = timeObject.ShowInRequestModule
            });
            timeObjectUpdates.Add(new
            {
                where = new { timeobj_id = new { _eq = timeObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = timeObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowTimeObjects, timeObjectUpdates, updatedTimeObjects.Count);
        foreach (FlowTimeObject updatedObject in updatedTimeObjects)
        {
            ReplaceFlowTimeObjectInCatalog(updatedObject);
        }
    }

    /// <summary>
    /// Recalculates names for all supported flow object types using the configured management ranking.
    /// </summary>
    private async Task RecalculateNamesAsync(IReadOnlyList<int> preferredManagementRanking)
    {
        List<FlowNwObject> updatedNwObjects = [];
        List<object> nwObjectUpdates = [];
        foreach (FlowNwObject nwObject in flowNwObjects.ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveNwObjectNameByRanking(nwObject, namingNetworkObjectManagements, preferredManagementRanking, nwObject.Name ?? "");
            if (string.Equals(resolvedName, nwObject.Name, StringComparison.Ordinal))
            {
                continue;
            }

            updatedNwObjects.Add(new FlowNwObject
            {
                Id = nwObject.Id,
                Name = resolvedName,
                IpStart = nwObject.IpStart,
                IpEnd = nwObject.IpEnd,
                Hash = nwObject.Hash,
                State = nwObject.State,
                RemovedDate = nwObject.RemovedDate,
                ShowInRequestModule = nwObject.ShowInRequestModule
            });
            nwObjectUpdates.Add(new
            {
                where = new { nwobj_id = new { _eq = nwObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = nwObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowNwObjects, nwObjectUpdates, updatedNwObjects.Count);
        foreach (FlowNwObject updatedObject in updatedNwObjects)
        {
            ReplaceFlowNwObjectInCatalog(updatedObject);
        }

        List<FlowNwGroup> updatedNwGroups = [];
        List<object> nwGroupUpdates = [];
        foreach (FlowNwGroup nwGroup in flowNwGroups.ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveNwGroupNameByRanking(nwGroup, namingNetworkGroupManagements, preferredManagementRanking, nwGroup.Name);
            if (string.Equals(resolvedName, nwGroup.Name, StringComparison.Ordinal))
            {
                continue;
            }

            updatedNwGroups.Add(new FlowNwGroup
            {
                Id = nwGroup.Id,
                Name = resolvedName,
                Hash = nwGroup.Hash,
                State = nwGroup.State,
                RemovedDate = nwGroup.RemovedDate,
                ShowInRequestModule = nwGroup.ShowInRequestModule,
                NwGroupMembers = [.. nwGroup.NwGroupMembers]
            });
            nwGroupUpdates.Add(new
            {
                where = new { nwgrp_id = new { _eq = nwGroup.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = nwGroup.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowNwGroups, nwGroupUpdates, updatedNwGroups.Count);
        foreach (FlowNwGroup updatedGroup in updatedNwGroups)
        {
            ReplaceFlowNwGroupInCatalog(updatedGroup);
        }

        List<FlowSvcObject> updatedSvcObjects = [];
        List<object> svcObjectUpdates = [];
        foreach (FlowSvcObject svcObject in flowSvcObjects.ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveSvcObjectNameByRanking(svcObject, namingServiceManagements, preferredManagementRanking, svcObject.Name);
            if (string.Equals(resolvedName, svcObject.Name, StringComparison.Ordinal))
            {
                continue;
            }

            updatedSvcObjects.Add(new FlowSvcObject
            {
                Id = svcObject.Id,
                Name = resolvedName,
                PortStart = svcObject.PortStart,
                PortEnd = svcObject.PortEnd,
                ProtoId = svcObject.ProtoId,
                Hash = svcObject.Hash,
                State = svcObject.State,
                RemovedDate = svcObject.RemovedDate,
                ShowInRequestModule = svcObject.ShowInRequestModule
            });
            svcObjectUpdates.Add(new
            {
                where = new { svcobj_id = new { _eq = svcObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = svcObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowSvcObjects, svcObjectUpdates, updatedSvcObjects.Count);
        foreach (FlowSvcObject updatedObject in updatedSvcObjects)
        {
            ReplaceFlowSvcObjectInCatalog(updatedObject);
        }

        List<FlowSvcGroup> updatedSvcGroups = [];
        List<object> svcGroupUpdates = [];
        foreach (FlowSvcGroup svcGroup in flowSvcGroups.ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveSvcGroupNameByRanking(svcGroup, namingServiceManagements, preferredManagementRanking, svcGroup.Name);
            if (string.Equals(resolvedName, svcGroup.Name, StringComparison.Ordinal))
            {
                continue;
            }

            updatedSvcGroups.Add(new FlowSvcGroup
            {
                Id = svcGroup.Id,
                Name = resolvedName,
                Hash = svcGroup.Hash,
                State = svcGroup.State,
                RemovedDate = svcGroup.RemovedDate,
                ShowInRequestModule = svcGroup.ShowInRequestModule,
                SvcGroupMembers = [.. svcGroup.SvcGroupMembers]
            });
            svcGroupUpdates.Add(new
            {
                where = new { svcgrp_id = new { _eq = svcGroup.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = svcGroup.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowSvcGroups, svcGroupUpdates, updatedSvcGroups.Count);
        foreach (FlowSvcGroup updatedGroup in updatedSvcGroups)
        {
            ReplaceFlowSvcGroupInCatalog(updatedGroup);
        }

        List<FlowTimeObject> updatedTimeObjects = [];
        List<object> timeObjectUpdates = [];
        foreach (FlowTimeObject timeObject in flowTimeObjects.ToList())
        {
            string resolvedName = FlowNamingHelper.ResolveTimeObjectNameByRanking(timeObject, namingTimeManagements, preferredManagementRanking, timeObject.Name);
            if (string.Equals(resolvedName, timeObject.Name, StringComparison.Ordinal))
            {
                continue;
            }

            updatedTimeObjects.Add(new FlowTimeObject
            {
                Id = timeObject.Id,
                Name = resolvedName,
                StartTime = timeObject.StartTime,
                EndTime = timeObject.EndTime,
                Hash = timeObject.Hash,
                State = timeObject.State,
                RemovedDate = timeObject.RemovedDate,
                ShowInRequestModule = timeObject.ShowInRequestModule
            });
            timeObjectUpdates.Add(new
            {
                where = new { timeobj_id = new { _eq = timeObject.Id } },
                _set = new
                {
                    name = resolvedName,
                    show_in_request_module = timeObject.ShowInRequestModule
                }
            });
        }
        await SendFlowBatchUpdateAsync(FlowMutations.updateFlowTimeObjects, timeObjectUpdates, updatedTimeObjects.Count);
        foreach (FlowTimeObject updatedObject in updatedTimeObjects)
        {
            ReplaceFlowTimeObjectInCatalog(updatedObject);
        }
    }
}
